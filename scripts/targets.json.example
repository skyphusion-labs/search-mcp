{
  "_comment": "Copy to targets.json (./targets.json for npm CLI, or scripts/targets.json in a git clone). repos are directory names under SYNC_REPO_ROOT (default: cwd for npm, parent of this repo for dev clone). Only git-tracked files are uploaded.",
  "excludePaths": {
    "example-repo": ["vendor/private-notes/"]
  },
  "restrictedRepos": [],
  "targets": {
    "corpus": {
      "instance": "my-ai-search-instance",
      "bucket": "my-search-corpus",
      "repos": ["example-repo"]
    }
  }
}
